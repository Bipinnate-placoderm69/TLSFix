{
    items = (
        {
            cell = PSGroupCell;
            label = "Protocol";
            footerText = "mbedTLS gives legacy iOS modern HTTPS. TLS 1.3 is preferred and negotiates down to 1.2. Fallback routes sites mbedTLS can't handshake (e.g. TLS 1.0/1.1-only) to iOS's own stack on retry.";
        },
        {
            cell = PSSwitchCell;
            label = "TLS 1.3";
            key = tls13;
            default = 1;
            defaults = "com.tlsfix";
            PostNotification = "com.tlsfix.prefschanged";
        },
        {
            cell = PSSwitchCell;
            label = "Fallback to iOS TLS (legacy sites)";
            key = systemFallback;
            default = 1;
            defaults = "com.tlsfix";
            PostNotification = "com.tlsfix.prefschanged";
        },
        {
            cell = PSGroupCell;
            label = "Advanced";
            footerText = "Bounded drain caps the post-handshake read loop as a safety limit against a pathological stall. Leave on unless debugging.";
        },
        {
            cell = PSSwitchCell;
            label = "Bounded drain (safety)";
            key = drainGuard;
            default = 1;
            defaults = "com.tlsfix";
            PostNotification = "com.tlsfix.prefschanged";
        },
        {
            cell = PSSwitchCell;
            label = "Debug logging";
            key = debug;
            default = 0;
            defaults = "com.tlsfix";
            PostNotification = "com.tlsfix.prefschanged";
        },
        {
            cell = PSGroupCell;
            label = "Enabling apps";
            footerText = "The graphical app picker (AppList) isn't available on this iOS, so choose apps by hand. Edit /var/mobile/Library/Preferences/com.tlsfix.plist and add a line: enabled-<app bundle id> set to true for each app you want (Safari, com.apple.mobilesafari, is already on). Relaunch the app afterward.";
        }
    );
}
